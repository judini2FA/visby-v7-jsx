# ============================================================
# VISBY ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to git.
# ============================================================

# ── PRIVY ────────────────────────────────────────────────────
# Get from: https://privy.io > Dashboard > App ID
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id_here

# ── SUPABASE ─────────────────────────────────────────────────
# Get from: https://supabase.com > your project > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── HELIUS (Solana RPC) ───────────────────────────────────────
# Get from: https://helius.dev > Dashboard > RPC URL
# Use the DEVNET url for Phase 1
NEXT_PUBLIC_HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=your_helius_api_key

# ── MINT AUTHORITY ────────────────────────────────────────────
# A Solana keypair used server-side to pay for NFT mint fees
# Generate with: solana-keygen new --outfile mint-authority.json
# Then paste the JSON array here: [1,2,3,...]
# Fund it with devnet SOL: solana airdrop 2 <your-address> --url devnet
MINT_AUTHORITY_SECRET_KEY=[]

# ── STRIPE (Phase 2) ─────────────────────────────────────────
# Get from: https://stripe.com > Developers > API keys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ── COINBASE COMMERCE (Phase 2) ───────────────────────────────
COINBASE_COMMERCE_API_KEY=your_coinbase_commerce_api_key


# ── SEARCH (synonym expansion) ───────────────────────────────
# Curated color/material/item map is always on. Datamuse (free, no key) augments it.
# Set to "false" to disable the Datamuse network call and use the curated map only.
SEARCH_USE_DATAMUSE=true
